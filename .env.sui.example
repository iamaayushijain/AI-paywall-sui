# ── Required ──────────────────────────────────────────────────────────────────
# Get bech32 key by running: node scripts/export-sui-key.js
SUI_SERVER_SECRET_KEY=suiprivkey1...

# Package ID printed after: sui client publish --gas-budget 100000000
SUI_PACKAGE_ID=0x...

# ── Optional ──────────────────────────────────────────────────────────────────
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Address that receives payments. Defaults to server address if not set.
SUI_PUBLISHER_ADDRESS=0x...

# Price per request in MIST (1 SUI = 1_000_000_000 MIST). Default: 0.001 SUI
SUI_PRICE_MIST=1000000

PORT=3001
