# ─── Solana (existing) ────────────────────────────────────────────────────────
WALLET_ADDRESS=YourSolanaWalletBase58...
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HMAC secrets — generate with: openssl rand -hex 32
PAYWALL_CHALLENGE_SECRET=7e9fad88cd64b3b11874edecb6c9a6a9cff2a4c4f005208cc4ed3f78743a4417
PAYWALL_AUTH_SECRET=99000f003b7692ed92f23a811496231dc7a748f9c3c11f4eb3287059293318c1
PAYWALL_AUTH_DOMAIN=localhost:3000

# Optional: fee payer keypair for auto-creating recipient USDC ATAs
FACILITATOR_FEE_PAYER_SECRET_KEY
PORT=3000

# ─── Dodo Payments — Agent MCP server ────────────────────────────────────────
# The agent's OWN Dodo credentials (separate from the publisher's)
DODO_AGENT_API_KEY=                    # agent's Dodo API key
DODO_AGENT_PAYMENT_METHOD_ID=pm_xxx   # pre-saved card/payment method in Dodo
MAX_PRICE_USD=0.10                     # hard cap per request
POLL_TIMEOUT_MS=60000                  # max wait for payment webhook (ms)

# ─── Dodo Payments adapter (feature/dodo-adapter) ────────────────────────────
# API key from Dodo dashboard
DODO_PAYMENTS_API_KEY=

# Webhook signing secret (from Dodo dashboard → Webhooks)
DODO_PAYMENTS_WEBHOOK_KEY=

# test_mode (default) or live_mode
DODO_ENVIRONMENT=test_mode

# Product ID from Dodo dashboard — represents one "AI content access" unit
DODO_PRODUCT_ID=

# Secret for signing content JWTs — generate with: openssl rand -hex 32
JWT_SECRET=

# Public URL of this facilitator server (used in Dodo return_url / cancel_url)
FACILITATOR_URL=